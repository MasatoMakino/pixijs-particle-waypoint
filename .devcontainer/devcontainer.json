{
  "name": "${localWorkspaceFolderBasename} npm Runner",
  "build": { "dockerfile": "Dockerfile" },
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/${localWorkspaceFolderBasename},type=bind,consistency=cached",
  "remoteUser": "node",
  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW",
    "--shm-size=2g",
    "--name=${localWorkspaceFolderBasename}-npm-runner",
    "--security-opt",
    "seccomp=${localWorkspaceFolder}/.devcontainer/seccomp-chrome.json",
    "-p",
    "127.0.0.1:0:3000"
  ],
  "postCreateCommand": "npm ci",
  "postStartCommand": "sudo /usr/local/bin/init-firewall.sh && (npm audit --audit-level=moderate || true)",
  "containerEnv": {
    "NODE_ENV": "development",
    "NPM_CONFIG_AUDIT": "true"
  }
}
